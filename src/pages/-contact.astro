---
import '../styles/site.css';
const siteId   = "P2460";
const siteName = "Pawspurrfect Pet Care Service";
const baseUrl  = "/P2460";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact Us | Pawspurrfect Pet Care Service, Keighley</title>
  <meta name="description" content="Get in touch with Pawspurrfect Pet Care Service. Call 07703368164 or email enquiries@pawspurrfect.co.uk. Based in Arbour Top, Keighley." />
  <link rel="icon" type="image/png" href="/favicon.png" />
</head>
<body>

  <!-- Preview Banner -->
  <div class="bg-[#1C3F1B] text-white text-center text-sm py-2 px-4">
    Preview redesign for Pawspurrfect Pet Care Service by
    <a href={`https://biscuitweb.co.uk/activate?id=${siteId}&name=Pawspurrfect%20Pet%20Care%20Service`} class="underline font-semibold ml-1">Biscuit Web</a>
  </div>

  <!-- Header -->
  <header class="bg-[#2D6A2C] text-white sticky top-0 z-50 shadow-lg">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href={baseUrl} class="font-display font-bold text-lg leading-tight text-white">
        🐾 Pawspurrfect<br class="hidden sm:block" /><span class="text-sm font-normal opacity-90">Pet Care Service</span>
      </a>
      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-6 text-sm font-semibold">
        <a href={baseUrl} class="text-white hover:text-[#F5C518] transition-colors">Home</a>
        <a href={`${baseUrl}/-about`} class="text-white hover:text-[#F5C518] transition-colors">About Me</a>
        <a href={`${baseUrl}/-location`} class="text-white hover:text-[#F5C518] transition-colors">Our Location</a>
        <a href={`${baseUrl}/-pet-plans`} class="text-white hover:text-[#F5C518] transition-colors">Pet Care Plans</a>
        <a href={`${baseUrl}/-contact`} class="bg-[#F5C518] text-[#1C3F1B] px-4 py-2 rounded font-bold hover:bg-yellow-400 transition-colors">Contact Us</a>
      </nav>
      <!-- Mobile Hamburger -->
      <button id="menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Open menu">
        <span class="block w-6 h-0.5 bg-white"></span>
        <span class="block w-6 h-0.5 bg-white"></span>
        <span class="block w-6 h-0.5 bg-white"></span>
      </button>
    </div>
    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-[#1C3F1B] px-4 pb-4">
      <nav class="flex flex-col gap-3 text-sm font-semibold pt-2">
        <a href={baseUrl} class="text-white hover:text-[#F5C518] py-1 border-b border-[#2D6A2C]">Home</a>
        <a href={`${baseUrl}/-about`} class="text-white hover:text-[#F5C518] py-1 border-b border-[#2D6A2C]">About Me</a>
        <a href={`${baseUrl}/-location`} class="text-white hover:text-[#F5C518] py-1 border-b border-[#2D6A2C]">Our Location</a>
        <a href={`${baseUrl}/-pet-plans`} class="text-white hover:text-[#F5C518] py-1 border-b border-[#2D6A2C]">Pet Care Plans</a>
        <a href={`${baseUrl}/-contact`} class="text-[#F5C518] py-1">Contact Us</a>
      </nav>
    </div>
  </header>

  <!-- Page Hero -->
  <section class="bg-[#2D6A2C] py-14">
    <div class="max-w-6xl mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-display font-bold text-white mb-3">Get in Touch</h1>
      <p class="text-white/80 text-lg max-w-xl">I'd love to hear from you. Whether you have a question about my services or you're ready to book, get in touch and I'll get back to you as soon as I can.</p>
    </div>
  </section>

  <!-- Contact Details + Form -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12">

        <!-- Contact Details -->
        <div>
          <h2 class="text-2xl font-display font-bold text-[#1C3F1B] mb-6">Contact Details</h2>

          <div class="space-y-5 mb-8">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-[#F0F7EF] rounded-full flex items-center justify-center text-lg flex-shrink-0">📍</div>
              <div>
                <div class="font-semibold text-[#1C3F1B]">Address</div>
                <div class="text-[#3D5C3C] text-sm">Arbour Top, Keighley</div>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-[#F0F7EF] rounded-full flex items-center justify-center text-lg flex-shrink-0">📞</div>
              <div>
                <div class="font-semibold text-[#1C3F1B]">Mobile</div>
                <a href="tel:+447703368164" class="text-[#2D6A2C] font-semibold hover:underline">07703368164</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-[#F0F7EF] rounded-full flex items-center justify-center text-lg flex-shrink-0">✉️</div>
              <div>
                <div class="font-semibold text-[#1C3F1B]">Email</div>
                <a href="mailto:enquiries@pawspurrfect.co.uk" class="text-[#2D6A2C] font-semibold hover:underline">enquiries@pawspurrfect.co.uk</a>
              </div>
            </div>
          </div>

          <!-- Free Consultation callout -->
          <div class="bg-[#F5C518]/20 border border-[#F5C518] rounded-xl p-5 mb-8">
            <h3 class="font-display font-bold text-[#1C3F1B] text-base mb-2">💬 Free Consultation</h3>
            <p class="text-sm text-[#3D5C3C]">
              Call me to arrange a free, no-obligation consultation for your pet. If you're unsure about any of the information, or unsure whether I cover your area, just get in touch and I'll help.
            </p>
          </div>

          <!-- Map -->
          <h2 class="text-xl font-display font-bold text-[#1C3F1B] mb-4">Find us on the map</h2>
          <div class="rounded-xl overflow-hidden border border-[#B8D9B6] shadow-sm">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d9400.383928300962!2d-1.9887762540893632!3d53.91227029076771!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x487bf2194b6619e1%3A0x3f10ba51682947f2!2sFarnhill!5e0!3m2!1sen!2sus!4v1397420320391"
              width="100%"
              height="280"
              style="border:0;"
              loading="lazy"
              allowfullscreen
              title="Map showing Farnhill, near Keighley"
            ></iframe>
          </div>
        </div>

        <!-- Contact Form -->
        <div>
          <h2 class="text-2xl font-display font-bold text-[#1C3F1B] mb-6">Send a Message</h2>
          <form action="https://formspree.io/f/mwvaaojq" method="POST" class="space-y-5">
            <div>
              <label for="name" class="block text-sm font-semibold text-[#1C3F1B] mb-1">Your name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Your name"
                class="w-full border border-[#B8D9B6] rounded-lg px-4 py-3 text-sm text-[#1C3F1B] placeholder-[#3D5C3C]/50 focus:outline-none focus:border-[#2D6A2C] focus:ring-1 focus:ring-[#2D6A2C] bg-white"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-semibold text-[#1C3F1B] mb-1">Email address</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="your@email.com"
                class="w-full border border-[#B8D9B6] rounded-lg px-4 py-3 text-sm text-[#1C3F1B] placeholder-[#3D5C3C]/50 focus:outline-none focus:border-[#2D6A2C] focus:ring-1 focus:ring-[#2D6A2C] bg-white"
              />
            </div>
            <div>
              <label for="phone" class="block text-sm font-semibold text-[#1C3F1B] mb-1">Phone number (optional)</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                placeholder="07700 000000"
                class="w-full border border-[#B8D9B6] rounded-lg px-4 py-3 text-sm text-[#1C3F1B] placeholder-[#3D5C3C]/50 focus:outline-none focus:border-[#2D6A2C] focus:ring-1 focus:ring-[#2D6A2C] bg-white"
              />
            </div>
            <div>
              <label for="service" class="block text-sm font-semibold text-[#1C3F1B] mb-1">Service you're interested in</label>
              <select
                id="service"
                name="service"
                class="w-full border border-[#B8D9B6] rounded-lg px-4 py-3 text-sm text-[#1C3F1B] focus:outline-none focus:border-[#2D6A2C] focus:ring-1 focus:ring-[#2D6A2C] bg-white"
              >
                <option value="">Please select...</option>
                <option value="Home from Home Boarding">Home from Home Boarding</option>
                <option value="Pet Visiting">Pet Visiting</option>
                <option value="Dog Walking">Dog Walking</option>
                <option value="Pet Taxi">Pet Taxi</option>
                <option value="Not sure yet">Not sure yet</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-semibold text-[#1C3F1B] mb-1">Your message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                placeholder="Tell me a bit about your pet and what you need..."
                class="w-full border border-[#B8D9B6] rounded-lg px-4 py-3 text-sm text-[#1C3F1B] placeholder-[#3D5C3C]/50 focus:outline-none focus:border-[#2D6A2C] focus:ring-1 focus:ring-[#2D6A2C] bg-white resize-none"
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full bg-[#2D6A2C] text-white py-3 rounded-lg font-bold hover:bg-[#1C3F1B] transition-colors"
            >
              Send Message
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-[#1C3F1B] text-white pt-12 pb-6">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8 mb-8">
        <div>
          <h3 class="font-display font-bold text-lg mb-3">🐾 Pawspurrfect</h3>
          <p class="text-white/70 text-sm leading-relaxed">Specialist pet care when you can't be there. Family run, fully insured, Bradford Council regulated and NARP registered.</p>
        </div>
        <div>
          <h3 class="font-display font-bold text-base mb-3">Pages</h3>
          <ul class="space-y-2 text-sm">
            <li><a href={baseUrl} class="text-white/70 hover:text-white transition-colors">Home</a></li>
            <li><a href={`${baseUrl}/-about`} class="text-white/70 hover:text-white transition-colors">About Me</a></li>
            <li><a href={`${baseUrl}/-location`} class="text-white/70 hover:text-white transition-colors">Our Location</a></li>
            <li><a href={`${baseUrl}/-pet-plans`} class="text-white/70 hover:text-white transition-colors">Pet Care Plans</a></li>
            <li><a href={`${baseUrl}/-contact`} class="text-white/70 hover:text-white transition-colors">Contact Us</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-display font-bold text-base mb-3">Contact</h3>
          <ul class="space-y-2 text-sm text-white/70">
            <li>📍 Arbour Top, Keighley</li>
            <li><a href="tel:+447703368164" class="hover:text-white transition-colors">📞 07703368164</a></li>
            <li><a href="mailto:enquiries@pawspurrfect.co.uk" class="hover:text-white transition-colors">✉️ enquiries@pawspurrfect.co.uk</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-white/10 pt-6 text-center text-sm text-white/40">
        &copy; {new Date().getFullYear()} Pawspurrfect Pet Care Service. All rights reserved.
      </div>
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('menu-toggle');
    const menu   = document.getElementById('mobile-menu');
    if (toggle && menu) {
      toggle.addEventListener('click', () => menu.classList.toggle('hidden'));
    }
  </script>

</body>
</html>
