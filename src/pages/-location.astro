---
import '../styles/site.css';
const siteId   = "P2460";
const siteName = "Pawspurrfect Pet Care Service";
const baseUrl  = "/P2460";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Our Location | Pawspurrfect Pet Care Service, Keighley</title>
  <meta name="description" content="Pawspurrfect covers Keighley, Silsden, Ilkley, Skipton, Addingham and the Wharfedale area. Based near Farnhill Moor with spacious rural grounds for your pet." />
  <link rel="icon" type="image/png" href="/favicon.png" />
</head>
<body>

  <!-- Preview Banner -->
  <div class="bg-[#1C3F1B] text-white text-center text-sm py-2 px-4">
    Preview redesign for Pawspurrfect Pet Care Service by
    <a href={`https://biscuitweb.co.uk/activate?id=${siteId}&name=Pawspurrfect%20Pet%20Care%20Service`} class="underline font-semibold ml-1">Biscuit Web</a>
  </div>

  <!-- Header -->
  <header class="bg-[#2D6A2C] text-white sticky top-0 z-50 shadow-lg">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href={baseUrl} class="font-display font-bold text-lg leading-tight text-white">
        🐾 Pawspurrfect<br class="hidden sm:block" /><span class="text-sm font-normal opacity-90">Pet Care Service</span>
      </a>
      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-6 text-sm font-semibold">
        <a href={baseUrl} class="text-white hover:text-[#F5C518] transition-colors">Home</a>
        <a href={`${baseUrl}/-about`} class="text-white hover:text-[#F5C518] transition-colors">About Me</a>
        <a href={`${baseUrl}/-location`} class="text-[#F5C518]">Our Location</a>
        <a href={`${baseUrl}/-pet-plans`} class="text-white hover:text-[#F5C518] transition-colors">Pet Care Plans</a>
        <a href={`${baseUrl}/-contact`} class="bg-[#F5C518] text-[#1C3F1B] px-4 py-2 rounded font-bold hover:bg-yellow-400 transition-colors">Contact Us</a>
      </nav>
      <!-- Mobile Hamburger -->
      <button id="menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Open menu">
        <span class="block w-6 h-0.5 bg-white"></span>
        <span class="block w-6 h-0.5 bg-white"></span>
        <span class="block w-6 h-0.5 bg-white"></span>
      </button>
    </div>
    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-[#1C3F1B] px-4 pb-4">
      <nav class="flex flex-col gap-3 text-sm font-semibold pt-2">
        <a href={baseUrl} class="text-white hover:text-[#F5C518] py-1 border-b border-[#2D6A2C]">Home</a>
        <a href={`${baseUrl}/-about`} class="text-white hover:text-[#F5C518] py-1 border-b border-[#2D6A2C]">About Me</a>
        <a href={`${baseUrl}/-location`} class="text-[#F5C518] py-1 border-b border-[#2D6A2C]">Our Location</a>
        <a href={`${baseUrl}/-pet-plans`} class="text-white hover:text-[#F5C518] py-1 border-b border-[#2D6A2C]">Pet Care Plans</a>
        <a href={`${baseUrl}/-contact`} class="text-white hover:text-[#F5C518] py-1">Contact Us</a>
      </nav>
    </div>
  </header>

  <!-- Page Hero -->
  <section class="bg-[#1A6BA0] py-14">
    <div class="max-w-6xl mx-auto px-4">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/30 text-white text-sm font-semibold px-3 py-1 rounded-full mb-4">
        <span>📍</span> Silsden, Keighley
      </div>
      <h1 class="text-4xl md:text-5xl font-display font-bold text-white mb-3">Our Location</h1>
      <p class="text-white/80 text-lg max-w-xl">I'm based near Silsden and cover a wide area across West Yorkshire. Close to the moors and countryside your dog will love.</p>
    </div>
  </section>

  <!-- Coverage Area -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="text-2xl font-display font-bold text-[#1C3F1B] mb-4">Spacious Rural Location</h2>
          <p class="text-[#3D5C3C] mb-4">
            Paws Purrfect is a family run business based near Silsden. With extensive gardens and fields at home, and close proximity to Addingham Moorside and Farnhill Moor, I'm ideally situated for your pet.
          </p>
          <p class="text-[#3D5C3C] mb-6">
            My general working area covers the triangle between Keighley, Ilkley and Skipton. If you're unsure whether you're within my coverage area, please don't hesitate to get in touch.
          </p>

          <h2 class="text-2xl font-display font-bold text-[#1C3F1B] mb-4">Areas I cover</h2>
          <div class="grid grid-cols-2 gap-3 mb-6">
            {[
              { name: "Keighley", icon: "🏙️" },
              { name: "Silsden", icon: "🏡" },
              { name: "Ilkley", icon: "🌳" },
              { name: "Skipton", icon: "🏰" },
              { name: "Addingham", icon: "🌾" },
              { name: "Wharfedale", icon: "🌊" },
              { name: "Farnhill", icon: "⛰️" },
              { name: "Surrounding area", icon: "📍" },
            ].map(area => (
              <div class="flex items-center gap-2 bg-[#F0F7EF] rounded-lg px-3 py-2 border border-[#B8D9B6]">
                <span>{area.icon}</span>
                <span class="text-sm font-semibold text-[#1C3F1B]">{area.name}</span>
              </div>
            ))}
          </div>

          <div class="bg-[#F5C518]/20 border border-[#F5C518] rounded-xl p-4">
            <p class="text-[#1C3F1B] text-sm font-medium">
              Not sure if you're in my area? Give me a call on <a href="tel:+447703368164" class="font-bold underline">07703368164</a> and I'll let you know.
            </p>
          </div>
        </div>

        <div class="space-y-6">
          <!-- Map -->
          <div class="rounded-xl overflow-hidden border border-[#B8D9B6] shadow-sm">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d9400.383928300962!2d-1.9887762540893632!3d53.91227029076771!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x487bf2194b6619e1%3A0x3f10ba51682947f2!2sFarnhill!5e0!3m2!1sen!2sus!4v1397420320391"
              width="100%"
              height="340"
              style="border:0;"
              loading="lazy"
              allowfullscreen
              title="Map showing Farnhill, near Keighley"
            ></iframe>
          </div>

          <!-- What's nearby -->
          <div class="bg-[#F0F7EF] rounded-2xl p-6 border border-[#B8D9B6]">
            <h3 class="font-display font-bold text-[#1C3F1B] text-xl mb-4">🌿 What's nearby</h3>
            <ul class="space-y-3 text-sm text-[#3D5C3C]">
              <li class="flex items-start gap-3">
                <span class="text-[#2D6A2C] font-bold mt-0.5">⛰️</span>
                <span>Addingham Moorside, ideal for long off-lead walks</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-[#2D6A2C] font-bold mt-0.5">🌄</span>
                <span>Farnhill Moor, beautiful countryside walks</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-[#2D6A2C] font-bold mt-0.5">🏡</span>
                <span>Extensive gardens and private fields at home</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-[#2D6A2C] font-bold mt-0.5">🚗</span>
                <span>Convenient access to Keighley, Skipton, Ilkley and surrounding villages</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 bg-[#2D6A2C]">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-display font-bold text-white mb-3">Ready to get started?</h2>
      <p class="text-white/80 mb-6">Call me today to arrange a free consultation. I'll come to you, meet your pet, and we'll figure out the best plan together.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="tel:+447703368164" class="bg-[#F5C518] text-[#1C3F1B] px-6 py-3 rounded-lg font-bold hover:bg-yellow-400 transition-colors">
          📞 Call 07703368164
        </a>
        <a href={`${baseUrl}/-contact`} class="border-2 border-white text-white px-6 py-3 rounded-lg font-bold hover:bg-white hover:text-[#2D6A2C] transition-colors">
          Send a Message
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-[#1C3F1B] text-white pt-12 pb-6">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8 mb-8">
        <div>
          <h3 class="font-display font-bold text-lg mb-3">🐾 Pawspurrfect</h3>
          <p class="text-white/70 text-sm leading-relaxed">Specialist pet care when you can't be there. Family run, fully insured, Bradford Council regulated and NARP registered.</p>
        </div>
        <div>
          <h3 class="font-display font-bold text-base mb-3">Pages</h3>
          <ul class="space-y-2 text-sm">
            <li><a href={baseUrl} class="text-white/70 hover:text-white transition-colors">Home</a></li>
            <li><a href={`${baseUrl}/-about`} class="text-white/70 hover:text-white transition-colors">About Me</a></li>
            <li><a href={`${baseUrl}/-location`} class="text-white/70 hover:text-white transition-colors">Our Location</a></li>
            <li><a href={`${baseUrl}/-pet-plans`} class="text-white/70 hover:text-white transition-colors">Pet Care Plans</a></li>
            <li><a href={`${baseUrl}/-contact`} class="text-white/70 hover:text-white transition-colors">Contact Us</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-display font-bold text-base mb-3">Contact</h3>
          <ul class="space-y-2 text-sm text-white/70">
            <li>📍 Arbour Top, Keighley</li>
            <li><a href="tel:+447703368164" class="hover:text-white transition-colors">📞 07703368164</a></li>
            <li><a href="mailto:enquiries@pawspurrfect.co.uk" class="hover:text-white transition-colors">✉️ enquiries@pawspurrfect.co.uk</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-white/10 pt-6 text-center text-sm text-white/40">
        &copy; {new Date().getFullYear()} Pawspurrfect Pet Care Service. All rights reserved.
      </div>
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('menu-toggle');
    const menu   = document.getElementById('mobile-menu');
    if (toggle && menu) {
      toggle.addEventListener('click', () => menu.classList.toggle('hidden'));
    }
  </script>

</body>
</html>
